{
  "name": "react-nestjs-ssr-starter",
  "version": "0.0.1",
  "description": "A lightweight full-stack starter for server-side rendering with NestJS and React.",
  "type": "module",
  "scripts": {
    "dev": "APP_ENV=development node --experimental-strip-types --experimental-vm-modules --enable-source-maps scripts/start.ts",
    "build": "rsbuild build --config ./scripts/rsbuild.config.ts",
    "commitlint": "commitlint --config ./eng/.commitlintrc.json --edit",
    "cspell": "cspell --config ./eng/cspell.config.json --quiet .",
    "eslint": "eslint --config ./eng/eslint.config.js .",
    "lint": "npm run cspell && npm run eslint",
    "lint:staged": "lint-staged --config ./eng/.lintstagedrc.json",
    "postinstall": "husky || true",
    "prepreview": "npm run build",
    "preview": "APP_ENV=development node --enable-source-maps lib/main.js",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "type-check": "rm -rf ./node_modules/.cache/tsbuild && tsc --build ./tsconfig.json"
  },
  "author": "Dunn",
  "license": "MIT",
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@mantine/core": "^9.2.1",
    "@mantine/hooks": "^9.0.0",
    "@mikro-orm/core": "^7.1.1",
    "@mikro-orm/decorators": "^7.1.1",
    "@mikro-orm/nestjs": "^7.0.2",
    "@mikro-orm/sqlite": "^7.1.1",
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-fastify": "^11.1.23",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "deepmerge": "^4.3.1",
    "nestjs-zod": "^5.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@camaro/eslint-config": "^0.3.0",
    "@camaro/tsconfig": "^1.4.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.60.0",
    "@rsbuild/core": "^2.0.7",
    "@rsbuild/plugin-react": "^2.0.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "cspell": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "type-fest": "^5.5.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
